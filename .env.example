# MiniMax API 配置
# 复制此文件为 .env 并填入你的真实密钥

# API Key（sk-cp- 开头为 Token Plan Key，sk-api- 开头为 API Key）
MINIMAX_API_KEY=sk-cp-YOUR_TOKEN_PLAN_KEY_HERE

# API 地址（默认中国大陆）
MINIMAX_API_HOST=https://api.minimaxi.com

# 飞书机器人配置（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FEISHU_CHAT_ID=oc_x111111111111111111111111111111
